# Environment Configuration Template
# Copy this to .env.local and update with your settings

# Application
APP_NAME="Real-Time Poll Platform"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://polling.local

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=polling_system
DB_USER=root
DB_PASS=

# Security
CSRF_TOKEN_LENGTH=64
SESSION_TIMEOUT=1800

# Mail (optional, for future notifications)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@polling.local

# Rate Limiting (optional)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_MINUTES=1
